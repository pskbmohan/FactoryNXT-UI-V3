# ─────────────────────────────────────────────────
# FactoryNXT – Environment Variables Template
# Copy to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────

# ── Frontend (Vite) ──────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
# VITE_APP_NAME=FactoryNXT
# VITE_DEFAULT_PLANT=PLANT01

# MinIO public endpoint consumed by the frontend
# (pre-signed URLs are generated by the backend; this is for direct asset links)
VITE_MINIO_PUBLIC_URL=http://localhost:9000

# ── PostgreSQL ───────────────────────────────────
POSTGRES_USER=factorynxt
POSTGRES_PASSWORD=changeme_postgres
POSTGRES_DB=factorynxt_db
# Full DSN (used by backend directly if not constructed dynamically)
DATABASE_URL=postgresql+asyncpg://factorynxt:changeme_postgres@localhost:5432/factorynxt_db

# ── Redis ────────────────────────────────────────
REDIS_PASSWORD=changeme_redis
REDIS_URL=redis://:changeme_redis@localhost:6379/0

# ── MinIO ────────────────────────────────────────
MINIO_ACCESS_KEY=factorynxt_admin
MINIO_SECRET_KEY=changeme_minio_secret
MINIO_BUCKET_NAME=factorynxt
# Internal endpoint (used by backend inside Docker network)
MINIO_ENDPOINT=localhost:9000
MINIO_SECURE=false

# ── Backend / FastAPI ────────────────────────────
SECRET_KEY=changeme_jwt_secret_min_32_chars_long
ENVIRONMENT=development
# ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173
